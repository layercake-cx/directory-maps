# Copy this file to .env or .env.local and fill in real values.
#   cp .env.example .env
# Vite loads .env and .env.local from the project root. Restart the dev server after changing.
# For Vercel: set the same variables in Project → Settings → Environment Variables (per environment).

# Supabase (required for login, data, and embed maps)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Maps (required for map and geocoding)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional: Google Picker / Drive (for Google Sheet sync)
# VITE_GOOGLE_API_KEY=your-google-api-key

# Optional: Vercel Deploy Hooks (for one-click deploy from Admin → Deployments)
# Create in Vercel: Project → Settings → Git → Deploy Hooks. Use Preview for test, Production for live.
# VITE_DEPLOY_HOOK_PREVIEW=https://api.vercel.com/v1/integrations/deploy/...
# VITE_DEPLOY_HOOK_PRODUCTION=https://api.vercel.com/v1/integrations/deploy/...
