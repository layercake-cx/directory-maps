# Copy to .env.local for local development. Do not commit .env.local.
# For Vercel: set these in Project → Settings → Environment Variables (per environment).

# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Maps (required for map and geocoding)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional: Google Picker / Drive (for Google Sheet sync)
# VITE_GOOGLE_API_KEY=your-google-api-key
